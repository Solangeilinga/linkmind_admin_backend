{
  "name": "linkmind-admin-backend",
  "version": "1.0.0",
  "description": "LinkMind Admin - Backend Express API",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "build": "tsc",
